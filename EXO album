                            <label class="sub-item"><input type="checkbox" data-version="sfy-kor-baekhyun"> Baekhyun</label>
                            <label class="sub-item"><input type="checkbox" data-version="sfy-kor-chen"> Chen</label>
                            <label class="sub-item"><input type="checkbox" data-version="sfy-kor-chanyeol"> Chanyeol</label>
