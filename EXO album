<script>
    (function() {
        // 統計進度功能
        function updateStats() {
            const allCheckboxes = document.querySelectorAll('input[type="checkbox"]');
            const total = allCheckboxes.length;
            const collected = Array.from(allCheckboxes).filter(cb => cb.checked).length;
            const percent = total > 0 ? Math.round((collected / total) * 100) : 0;
            
            document.getElementById('collectedCount').textContent = collected;
            document.getElementById('totalVersions').textContent = total;
            document.getElementById('progressBarFill').style.width = percent + '%';
            document.getElementById('progressPercent').textContent = percent + '%';
        }

        // 保存 checkbox 狀態
        function saveCheckboxes() {
            const checkboxes = document.querySelectorAll('input[type="checkbox"]');
            const state = {};
            checkboxes.forEach(cb => {
                if (cb.dataset.version) {
                    state[cb.dataset.version] = cb.checked;
                }
            });
            localStorage.setItem('exoChecklist', JSON.stringify(state));
            updateStats();
        }

        function loadCheckboxes() {
            const saved = localStorage.getItem('exoChecklist');
            if (saved) {
                try {
                    const state = JSON.parse(saved);
                    const checkboxes = document.querySelectorAll('input[type="checkbox"]');
                    checkboxes.forEach(cb => {
                        if (cb.dataset.version && state.hasOwnProperty(cb.dataset.version)) {
                            cb.checked = state[cb.dataset.version];
                        }
                    });
                } catch(e) {}
            }
            updateStats();
        }

        document.querySelectorAll('input[type="checkbox"]').forEach(cb => {
            cb.addEventListener('change', saveCheckboxes);
        });

        // 封面圖片上傳功能
        function initCoverUpload() {
            const coverDivs = document.querySelectorAll('.cover-upload');
            
            coverDivs.forEach(div => {
                const input = div.querySelector('input[type="file"]');
                const albumKey = div.dataset.coverFor;
                
                const savedImage = localStorage.getItem(`cover_${albumKey}`);
                if (savedImage) {
                    div.style.backgroundImage = `url('${savedImage}')`;
                    div.style.backgroundSize = 'cover';
                    div.classList.add('has-image');
                    const placeholder = div.querySelector('.placeholder-text');
                    if (placeholder) placeholder.style.opacity = '0';
                }
                
                div.addEventListener('click', (e) => {
                    if (e.target.tagName !== 'INPUT') {
                        input.click();
                    }
                });
                
                input.addEventListener('change', (e) => {
                    const file = input.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = (event) => {
                            const imageData = event.target.result;
                            div.style.backgroundImage = `url('${imageData}')`;
                            div.style.backgroundSize = 'cover';
                            div.classList.add('has-image');
                            const placeholder = div.querySelector('.placeholder-text');
                            if (placeholder) placeholder.style.opacity = '0';
                            
                            try {
                                localStorage.setItem(`cover_${albumKey}`, imageData);
                            } catch(e) {
                                console.warn('圖片太大，無法保存');
                            }
                        };
                        reader.readAsDataURL(file);
                    }
                });
            });
        }

        // 匯出備份功能
        function exportBackup() {
            const backup = {
                checkboxes: {},
                covers: {}
            };
            
            document.querySelectorAll('input[type="checkbox"]').forEach(cb => {
                if (cb.dataset.version) {
                    backup.checkboxes[cb.dataset.version] = cb.checked;
                }
            });
            
            for (let i = 0; i < localStorage.length; i++) {
                const key = localStorage.key(i);
                if (key.startsWith('cover_')) {
                    backup.covers[key] = localStorage.getItem(key);
                }
            }
            
            const blob = new Blob([JSON.stringify(backup, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `exo_backup_${new Date().toISOString().slice(0,10)}.json`;
            a.click();
            URL.revokeObjectURL(url);
        }

        // 匯入備份功能
        function importBackup(file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const backup = JSON.parse(e.target.result);
                    
                    if (backup.checkboxes) {
                        document.querySelectorAll('input[type="checkbox"]').forEach(cb => {
                            if (cb.dataset.version && backup.checkboxes.hasOwnProperty(cb.dataset.version)) {
                                cb.checked = backup.checkboxes[cb.dataset.version];
                            }
                        });
                        saveCheckboxes();
                    }
                    
                    if (backup.covers) {
                        for (const key in backup.covers) {
                            localStorage.setItem(key, backup.covers[key]);
                        }
                        location.reload();
                    }
                    
                    alert('✅ 備份匯入成功！');
                } catch (error) {
                    alert('❌ 備份檔案格式錯誤');
                }
            };
            reader.readAsText(file);
        }

        // 分類篩選功能
        function initFilter() {
            const filterBtns = document.querySelectorAll('.filter-btn');
            const albumCards = document.querySelectorAll('.album-card');
            const yearSections = document.querySelectorAll('.year-section');
            const resultCount = document.getElementById('resultCount');

            function updateFilter(selectedFilter) {
                let visibleCount = 0;
                
                filterBtns.forEach(btn => {
                    btn.classList.remove('active');
                    if (btn.dataset.filter === selectedFilter) {
                        btn.classList.add('active');
                    }
                });

                albumCards.forEach(card => {
                    const category = card.dataset.category;
                    if (selectedFilter === 'all' || category === selectedFilter) {
                        card.classList.remove('hidden-card');
                        visibleCount++;
                    } else {
                        card.classList.add('hidden-card');
                    }
                });

                yearSections.forEach(section => {
                    const cardsInSection = section.querySelectorAll('.album-card');
                    const visibleCards = Array.from(cardsInSection).filter(card => !card.classList.contains('hidden-card'));
                    if (visibleCards.length === 0) {
                        section.classList.add('hidden-section');
                    } else {
                        section.classList.remove('hidden-section');
                    }
                });

                resultCount.textContent = `顯示 ${visibleCount} 張專輯`;
            }

            filterBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    const filter = btn.dataset.filter;
                    updateFilter(filter);
                });
            });

            updateFilter('all');
        }

        // 初始化
        loadCheckboxes();
        initCoverUpload();
        initFilter();
        
        // 備份按鈕事件
        document.getElementById('exportBtn').addEventListener('click', exportBackup);
        document.getElementById('importBtn').addEventListener('click', function() {
            document.getElementById('importFile').click();
        });
        document.getElementById('importFile').addEventListener('change', function(e) {
            if (this.files.length > 0) {
                importBackup(this.files[0]);
            }
        });
        
        // MutationObserver 確保新 checkbox 都有保存功能
        const observer = new MutationObserver(() => {
            document.querySelectorAll('input[type="checkbox"]').forEach(cb => {
                if (!cb.hasAttribute('data-listener')) {
                    cb.setAttribute('data-listener', 'true');
                    cb.addEventListener('change', saveCheckboxes);
                }
            });
        });
        observer.observe(document.body, { childList: true, subtree: true });
    })();
</script>

